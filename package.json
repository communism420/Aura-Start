{
  "name": "aura-start",
  "version": "2.0.5",
  "extensionVersions": {
    "chromium": "2.0.5",
    "firefox": "2.0.5"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "test": "node node_modules/vitest/vitest.mjs run",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "build": "node node_modules/typescript/bin/tsc --noEmit && node node_modules/vite/bin/vite.js build",
    "build:local": "node scripts/build-local.mjs",
    "build:firefox": "node scripts/build-firefox.mjs",
    "validate:store": "node scripts/validate-store.mjs",
    "validate:firefox": "node scripts/validate-firefox-build.mjs",
    "validate:firefox:submit": "node scripts/validate-firefox-build.mjs --submit-zip",
    "validate:zip": "node scripts/validate-chrome-submit-zip.mjs",
    "build:store": "node scripts/build-store.mjs",
    "preview": "node node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "fuse.js": "^7.4.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
